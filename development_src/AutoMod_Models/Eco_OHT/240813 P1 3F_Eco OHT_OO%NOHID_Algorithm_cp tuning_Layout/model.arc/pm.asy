VERSION 12.6.1.12
SYSTYPE AGVS
UNITS Millimeters Seconds
SYSDEF timeout 60 Seconds confname Config1
FLAGS
	System Inherit
	Text Inherit
	Paths Inherit
	Path Names Invisible Inherit
	Direction Invisible Inherit
	Vehicles Inherit
	Path Attach Points Invisible Inherit
	Control Points Invisible Inherit
	Control Point Names Invisible Inherit
	Transfers Invisible Inherit
AGVSDEF secname path6372 name cp_Route_9 UserId 2
	NEXTPATH name path6372 type DefaultGuidePath color 1
	NEXTCP name cp_Route_9 type Reroute
	ALTERNATE NONE ResumeSpeedWhenClaimed
	vel 0 Infinite Meters Seconds
	crabvel 0 Infinite Meters Seconds
	sprvel 0 Infinite Meters Seconds
	crvvel 0 Infinite Meters Seconds
AGVSTOL minang 150 maxang 1800
GPATHTYPE name DefaultGuidePath one normal attach rigid color -1 nav 1 vel 1 0 Meters Seconds 
