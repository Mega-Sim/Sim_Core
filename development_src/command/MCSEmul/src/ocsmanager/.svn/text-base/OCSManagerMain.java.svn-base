  /**
   * Micro Tr. CmdРЧ StatusПЁ ДыЧб Time АЛНХ
   * @param strMicroTrCmdID String
   * @param strStatusType String
   */
  void UpdateTrCmdStatusTime(String strMicroTrCmdID, String strStatusType)
  {
