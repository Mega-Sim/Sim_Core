    catch (SQLException e)
    {
      String strLog = "GetNextTrCmdInfo() - IOException: " + e.getMessage();
      WriteLog(strLog);
    }
    finally
    {
      if (rs != null)
      {
        m_dbFrame.CloseRecord(rs);
      }
    }

    strSql = "SELECT * FROM MicroTrCmd WHERE MacroTrCmdID='" + strMacroTrCmdID + "' AND CmdIndex=" +
        String.valueOf(nCmdIndex+1);
