  public void DisplayUserLongRunLogInText(String strLog)
  {
    if (m_Owner.jUserLongrunText.getLineCount() > 1000)
      m_Owner.jUserLongrunText.setText("");
    m_Owner.jUserLongrunText.append(strLog + "\n");
  }

