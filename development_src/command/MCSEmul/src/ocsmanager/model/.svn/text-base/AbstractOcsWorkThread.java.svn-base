package ocsmanager.model;

public abstract class AbstractOcsWorkThread extends Thread {
	
	public abstract String getThreadId();
	protected abstract void initialize();
	protected abstract void stopProcessing();
	protected abstract void mainProcessing();
	
	protected long interval = 1000;
	protected long sleepCount = 0;
	private boolean stopFlag = false;
	public boolean runFlag = false;
	
	private boolean hasInterval = false;

	protected AbstractOcsWorkThread() {
		initialize();
	}
	
	protected AbstractOcsWorkThread(long interval) {
		initialize();
		this.interval = interval;
	}
	
	public void run() {
		
		while(true) {
			hasInterval = false;
			while(runFlag) {
				try {
					mainProcessing();
				} catch (Exception e) {
					e.printStackTrace();
				}
				
				try {
					sleep(interval);
					hasInterval = true;
					sleepCount++;
				} catch (InterruptedException e) {
					e.printStackTrace();
				}
				if(stopFlag) {
					break;
				}
			}
			if(stopFlag) {
				stopProcessing();
				break;
			}
			if(hasInterval == false) {
				try {
					sleep(interval);
					hasInterval = true;
				} catch (InterruptedException e) {
					e.printStackTrace();
				}
			}
		}
	}
	
	public void setRunFlag(boolean runFlag) {
		this.runFlag = runFlag;
	}
	
	public void stopThread() {
		this.stopFlag = true;
	}
}
