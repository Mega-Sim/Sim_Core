<?xml version="1.0" encoding="UTF-8"?> 
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">

<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/" debug="true">
	
	<appender name="Console" class="org.apache.log4j.ConsoleAppender">
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<!-- UDPSendContent -->
	<appender name="UDPSendContentAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="UDPSendContentAsyncFile" />
	</appender>
	<appender name="UDPSendContentAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
		<param name="File" value="log/UDPSendContent.log" />
		<param name="Append" value="true" />
		<param name="DatePattern" value=".yyyyMMddHH" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name="UDPSendContent" additivity="true">
		<level value="trace" />
		<appender-ref ref="UDPSendContentAsync" />
	</logger>
	<!-- UDPRecvContent -->
	<appender name="UDPRecvContentAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="UDPRecvContentAsyncFile" />
	</appender>
	<appender name="UDPRecvContentAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
		<param name="File" value="log/UDPRecvContent.log" />
		<param name="Append" value="true" />
		<param name="DatePattern" value=".yyyyMMddHH" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name="UDPRecvContent" additivity="true">
		<level value="trace" />
		<appender-ref ref="UDPRecvContentAsync" />
	</logger>
	<!-- DBAccessManager -->
	<appender name="DBAccessManagerAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="DBAccessManagerAsyncFile" />
		<appender-ref ref="Console" />
	</appender>
	<appender name="DBAccessManagerAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
		<param name="File" value="log/DBAccessManager.log" />
		<param name="Append" value="true" />
		<param name="DatePattern" value=".yyyyMMddHH" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name="DBAccessManager" additivity="true">
		<level value="trace" />
		<appender-ref ref="DBAccessManagerAsync" />
	</logger>
	<!-- StartupHistory -->
	<appender name="StartupHistoryAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="StartupHistoryAsyncFile" />
	</appender>
	<appender name="StartupHistoryAsyncFile" class="org.apache.log4j.FileAppender">
		<param name="File" value="StartupHistory.log" />
		<param name="Append" value="true" />
		<!-- <param name="DatePattern" value=".yyyyMMddHH" />  -->
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name="StartupHistory" additivity="true">
		<level value="trace" />
		<appender-ref ref="StartupHistoryAsync" />
	</logger>
	<!-- don;t touch Common's area -->
	
	
<!-- Cluster Manager start -->
	<!-- ClusterManager -->
	<appender name="ClusterManagerAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="ClusterManagerAsyncFile" />
		<appender-ref ref="Console" />
	</appender>
	<appender name="ClusterManagerAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
		<param name="File" value="log/ClusterManager.log" />
		<param name="Append" value="true" />
		<param name="DatePattern" value=".yyyyMMddHH" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name="ClusterManager" additivity="true">
		<level value="trace" />
		<appender-ref ref="ClusterManagerAsync" />
	</logger>

<!-- Cluster Manager end -->
	
	
<!-- Cluster Interface -->
	<!-- ClusterExecuter -->
	<appender name="ClusterExecuterAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="ClusterExecuterAsyncFile" />
		<appender-ref ref="Console" />
	</appender>
	<appender name="ClusterExecuterAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
		<param name="File" value="log/ClusterExecuter.log" />
		<param name="Append" value="true" />
		<param name="DatePattern" value=".yyyyMMddHH" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name="ClusterExecuter" additivity="true">
		<level value="trace" />
		<appender-ref ref="ClusterExecuterAsync" />
	</logger>
	
	
<!-- OCS Manager -->
	<!-- OcsManagerDebug -->
	<appender name="OcsManagerDebugAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="OcsManagerDebugAsyncFile" />
	</appender>
	<appender name="OcsManagerDebugAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
		<param name="File" value="log/OcsManagerDebug.log" />
		<param name="Append" value="true" />
		<param name="DatePattern" value=".yyyyMMddHH" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name="OcsManagerDebug" additivity="true">
		<level value="trace" />
		<appender-ref ref="OcsManagerDebugAsync" />
	</logger>
	
	<appender name="OcsManagerExceptionAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="OcsManagerExceptionAsyncFile" />
	</appender>
	<appender name="OcsManagerExceptionAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
		<param name="File" value="log/OcsManagerException.log" />
		<param name="Append" value="true" />
		<param name="DatePattern" value=".yyyyMMddHH" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name=OcsManagerException additivity="true">
		<level value="trace" />
		<appender-ref ref="OcsManagerExceptionAsync" />
	</logger>
	
	
<!-- appender(async, dailyrolling) logger  -->


	
</log4j:configuration>