<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">

<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/" debug="true">

        <appender name="Console" class="org.apache.log4j.ConsoleAppender">
                <layout class="org.apache.log4j.PatternLayout">
                        <param name="ConversionPattern" value="%d{HH:mm:ss:SSS} %-5p - %m%n" />
                </layout>
        </appender>
 
<!-- stbc -->
	<appender name="STBCMainAsync" class="org.apache.log4j.AsyncAppender">
		<!-- bufferSize setting -->
		<param name="BufferSize" value="1024"/>	
		<param name="blocking" value="false" />
		<appender-ref ref="STBCMainAsyncFile" />
		<appender-ref ref="Console" />
	</appender>	
	<appender name="STBCMainAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
		<param name="File" value="log/STBCMain.log" />
		<param name="Append" value="true" />
		<param name="DatePattern" value="yyyy-MM-dd/%syyyyMMddHH" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{HH:mm:ss:SSS} %m%n" />
		</layout>
	</appender>
	<logger name="STBCMain" additivity="true">
		<level value="debug" />
		<appender-ref ref="STBCMainAsync" />		
	</logger>
        
<!-- stbcDelay -->
	<appender name="STBCDelayAsync" class="org.apache.log4j.AsyncAppender">
		<!-- bufferSize setting -->
<!--	<param name="BufferSize" value="1024"/>  -->
		<param name="blocking" value="false" />
		<appender-ref ref="STBCDelayAsyncFile" />
