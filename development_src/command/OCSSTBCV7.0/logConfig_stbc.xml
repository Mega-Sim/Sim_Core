			<param name="ConversionPattern" value="%d{HH:mm:ss:SSS} %m%n" />
		</layout>
	</appender>
	<logger name="STBCDelay" additivity="true">
		<level value="debug" />
		<appender-ref ref="STBCDelayAsync" />		
	</logger>
        
