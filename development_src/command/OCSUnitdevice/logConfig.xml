<?xml version="1.0" encoding="UTF-8"?> 
<!DOCTYPE log4j:configuration SYSTEM "log4j.dtd">

<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/" debug="true">
	<appender name="Console" class="org.apache.log4j.ConsoleAppender">
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	
<!-- StartupHistory -->
	<appender name="StartupHistoryAsync" class="org.apache.log4j.AsyncAppender">
		<param name="blocking" value="false" />
		<appender-ref ref="StartupHistoryAsyncFile" />
	</appender>
	<appender name="StartupHistoryAsyncFile" class="org.apache.log4j.FileAppender">
		<param name="File" value="StartupHistory.log" />
		<param name="Append" value="true" />
		<layout class="org.apache.log4j.PatternLayout">
			<param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
		</layout>
	</appender>
	<logger name="StartupHistory" additivity="true">
		<level value="info" />
		<appender-ref ref="StartupHistoryAsync" />
	</logger>
	
