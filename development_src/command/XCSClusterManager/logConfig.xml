<!-- stbc -->
        <appender name="stbcAsync" class="org.apache.log4j.AsyncAppender">
                <param name="blocking" value="false" />
                <appender-ref ref="stbcAsyncFile" />
        </appender>
        <appender name="stbcAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
                <param name="File" value="log/stbc.log" />
                <param name="Append" value="true" />
                <param name="DatePattern" value="yyyy-MM-dd/%syyyyMMddHH" />
                <layout class="org.apache.log4j.PatternLayout">
                        <param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
                </layout>
        </appender>
        <logger name="stbc" additivity="true">
                <level value="debug" />
                <appender-ref ref="stbcAsync" />
        </logger>
</log4j:configuration>
