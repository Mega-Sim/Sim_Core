        </appender>
        <logger name="jobassign" additivity="true">
                <level value="debug" />
                <appender-ref ref="jobassignAsync" />
        </logger>
<!-- ibsem -->
        <appender name="ibsemAsync" class="org.apache.log4j.AsyncAppender">
                <param name="blocking" value="false" />
                <appender-ref ref="ibsemAsyncFile" />
        </appender>
        <appender name="ibsemAsyncFile" class="com.samsung.xcs.commons.logger.XCSDailyRollingFileAppender">
                <param name="File" value="log/ibsem.log" />
                <param name="Append" value="true" />
                <param name="DatePattern" value="yyyy-MM-dd/%syyyyMMddHH" />
                <layout class="org.apache.log4j.PatternLayout">
                        <param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss:SSS} %-5p - %m%n" />
                </layout>
        </appender>
        <logger name="ibsem" additivity="true">
