[Version]
Signature="$WINDOWS NT$"
Class=Cantops
ClassGuid = {cfb15040-5bc7-11d3-b194-0060b0efd334}
Provider="CANTOPS"

[SourceDisksNames]
1=%DiskId%

[SourceDisksFiles]
amc_msdrv.sys=1

[ClassInstall32]
Addreg=AddHwClass

[AddHwClass]
HKR,,,,%ClassName%
HKR,,Icon,,"-5"

[DestinationDirs]
DefaultDestDir=12

[Manufacturer]
%Mfg%=MfgDeviceSection

[MfgDeviceSection]
%DeviceDesc% = amc_msdrv, amc_msdrv

[amc_msdrv]
CopyFiles=@amc_msdrv.sys

[amc_msdrv.Services]
AddService = amc_msdrv,%SPSVCINST_ASSOCSERVICE%,Cantops_Service_Inst

[Cantops_Service_Inst]
ServiceType    = %SERVICE_KERNEL_DRIVER%
StartType      = %SERVICE_MANUAL_START%
ErrorControl   = %SERVICE_ERROR_NORMAL%
ServiceBinary  = %12%\amc_msdrv.sys 

[Strings]
ClassName 	= "Cantops"
DeviceDesc 	= "Cantops AMC Multi Serial Driver"
DiskId 		= "Sample Install Disk 1"
Mfg = "CANTOPS"
SPSVCINST_ASSOCSERVICE = 0x00000002
SERVICE_KERNEL_DRIVER  = 1
SERVICE_MANUAL_START    = 3
SERVICE_ERROR_NORMAL  = 1