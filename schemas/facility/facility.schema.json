{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mega-sim.github.io/sim-core/schemas/facility/1.0.0",
  "title": "Sim_Core Canonical Facility Model",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "model_id",
    "revision_id",
    "content_hash",
    "coordinate_reference",
    "source_artifacts",
    "nodes",
    "edges",
    "stations"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "model_id": { "$ref": "#/$defs/id" },
    "revision_id": { "$ref": "#/$defs/id" },
    "content_hash": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*:[0-9a-f]+$"
    },
    "coordinate_reference": { "$ref": "#/$defs/coordinate_reference" },
    "source_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_artifact" }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/edge" }
    },
    "stations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/station" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "z"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "z": { "type": "integer" }
      }
    },
    "source_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_kind", "source_namespace", "external_id"],
      "properties": {
        "source_kind": { "type": "string", "minLength": 1 },
        "source_namespace": { "type": "string", "minLength": 1 },
        "external_id": { "type": "string", "minLength": 1 }
      }
    },
    "source_identities": {
      "type": "array",
      "items": { "$ref": "#/$defs/source_identity" }
    },
    "source_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "source_namespace",
        "sha256",
        "importer_name",
        "importer_version"
      ],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "source_namespace": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "importer_name": { "type": "string", "minLength": 1 },
        "importer_version": { "type": "string", "minLength": 1 }
      }
    },
    "coordinate_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frame", "length_unit", "up_axis", "handedness"],
      "properties": {
        "frame": { "type": "string", "minLength": 1 },
        "length_unit": { "const": "micrometer" },
        "up_axis": { "enum": ["X", "Y", "Z"] },
        "handedness": { "enum": ["left", "right"] }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "position_um", "layer", "role"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "position_um": { "$ref": "#/$defs/position" },
        "layer": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "source_identities": { "$ref": "#/$defs/source_identities" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from_node_id",
        "to_node_id",
        "length_um",
        "speed_limit_um_per_s",
        "polyline_um",
        "direction"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "from_node_id": { "$ref": "#/$defs/id" },
        "to_node_id": { "$ref": "#/$defs/id" },
        "length_um": { "type": "integer", "minimum": 1 },
        "speed_limit_um_per_s": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000000000000
        },
        "polyline_um": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/position" }
        },
        "direction": { "const": "ONE_WAY" },
        "source_identities": { "$ref": "#/$defs/source_identities" }
      }
    },
    "station": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "attachment_node_id", "operation_type"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "attachment_node_id": { "$ref": "#/$defs/id" },
        "operation_type": { "type": "string", "minLength": 1 },
        "semantic_tags": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_identities": { "$ref": "#/$defs/source_identities" }
      }
    }
  }
}
